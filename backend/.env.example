# Database
DATABASE_URL=postgresql://creator:password@localhost:5432/creator_assistant

# MiniMax AI
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_MODEL=MiniMax-Text-01

# Zhihu OAuth (from hackathon project creation)
ZHIHU_APP_ID=your_app_id
ZHIHU_APP_KEY=your_app_key
ZHIHU_ACCESS_SECRET=your_access_secret
FRONTEND_URL=http://localhost:5173
ZHIHU_REDIRECT_URI=http://localhost:5173/auth/callback

# Zhihu Developer API
ZHIHU_DEV_BASE_URL=https://developer.zhihu.com

# Hot scheduler source strategy for Zhihu:
# newsnow_first (default) | newsnow_only | native_only
HOT_ZHIHU_SOURCE_MODE=newsnow_first

# JWT
JWT_SECRET=change-this-to-random-string
JWT_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Development
BYPASS_OAUTH_LOGIN=false
