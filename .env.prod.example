# =============================================================================
# 生产环境变量模板 — 复制为 .env.prod 后填入真实值
# 此文件入仓库；.env.prod 不入仓库（已在 .gitignore 中排除）
# =============================================================================

# ---------- Database ----------
POSTGRES_PASSWORD=<生成32位随机字符串>

# ---------- Redis ----------
REDIS_PASSWORD=<生成16位随机字符串>

# ---------- JWT ----------
JWT_SECRET=<生成64位随机字符串>
JWT_EXPIRE_DAYS=7

# ---------- MiniMax AI ----------
MINIMAX_API_KEY=<实际密钥>
MINIMAX_MODEL=MiniMax-Text-01

# ---------- Zhihu OAuth ----------
ZHIHU_APP_ID=<实际值>
ZHIHU_APP_KEY=<实际值>
ZHIHU_ACCESS_SECRET=<实际值>
FRONTEND_URL=https://<APP_DOMAIN>
ZHIHU_REDIRECT_URI=https://<APP_DOMAIN>/auth/callback

# ---------- Zhihu Developer API ----------
ZHIHU_DEV_BASE_URL=https://developer.zhihu.com
HOT_ZHIHU_SOURCE_MODE=newsnow_first

# ---------- CORS ----------
CORS_ORIGINS=https://<APP_DOMAIN>

# ---------- Deploy version (managed by ops/deploy.sh) ----------
DEPLOY_VERSION=latest
